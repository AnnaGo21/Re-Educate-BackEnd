function fetchAPI(url) {
  fetch(url)
    .then((res) => res.json())
    .then((data) => console.log(data))
    .catch((error) => {
      console.log("error: ", error);
    }); //აი მაგალითად ამოაგდო აქ, რადგან url დავაზიანე განზრახ :დ
